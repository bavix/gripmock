--- META ---
name: array contains ignoreArrayOrder
summary: Test contains with ignoreArrayOrder for repeated field
tags: [array, matching, contains, ignoreArrayOrder]
owner: team/gripmock
links:
  - https://github.com/bavix/gripmock/issues/840

--- ENDPOINT ---
inventory.InventoryService/GetResourceDecorationByIPsStream

--- REQUEST ---
{
  "ips": [
    "10.0.4.1",
    "10.0.4.2"
  ],
  "k8s_cluster_id": "test-contains-ignore"
}

--- RESPONSE ---
{
  "ips_to_decorations": {
    "10.0.4.1": {
      "decoration": "contains-ok",
      "environment": "production"
    },
    "10.0.4.2": {
      "decoration": "contains-ok",
      "environment": "production"
    }
  }
}
