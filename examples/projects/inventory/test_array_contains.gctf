--- META ---
name: array contains
summary: Test contains matcher for repeated field
tags: [array, matching, contains]
owner: team/gripmock
links:
  - https://github.com/bavix/gripmock/issues/840

--- ENDPOINT ---
inventory.InventoryService/GetResourceDecorationByIPsStream

--- REQUEST ---
{
  "ips": [
    "10.0.1.1",
    "10.0.1.2"
  ],
  "k8s_cluster_id": "test-contains"
}

--- RESPONSE ---
{
  "ips_to_decorations": {
    "10.0.1.1": {
      "decoration": "web-frontend",
      "environment": "production"
    },
    "10.0.1.2": {
      "decoration": "web-frontend",
      "environment": "production"
    }
  }
}
