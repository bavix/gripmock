--- META ---
name: sequential retry scenario
summary: Test stateful stubs - first 2 calls return error, third returns success
tags: [sequential, stateful, retry]
owner: team/gripmock
links:
  - https://github.com/bavix/gripmock/issues/827

// First call - returns error (simulated transient failure)

--- ENDPOINT ---
inventory.InventoryService/GetResourceDecorationByIPsStream

--- REQUEST ---
{
  "k8s_cluster_id": "test-cluster"
}

--- ERROR ---
{
  "code": 14,
  "message": "simulated transient failure"
}
// Second call - returns error (first stub exhausted)

--- ENDPOINT ---
inventory.InventoryService/GetResourceDecorationByIPsStream

--- REQUEST ---
{
  "k8s_cluster_id": "test-cluster"
}

--- ERROR ---
{
  "code": 14,
  "message": "simulated transient failure"
}
// Third call - returns success (fallback stub)

--- ENDPOINT ---
inventory.InventoryService/GetResourceDecorationByIPsStream

--- REQUEST ---
{
  "k8s_cluster_id": "test-cluster"
}

--- RESPONSE partial with_asserts ---
{
  "ips_to_decorations": {
    "10.0.0.1": {
      "decoration": "web-frontend",
      
      //   "environment": "production"
    }
  }
}

--- ASSERTS ---
.ips_to_decorations["10.0.0.1"].environment != "production1"
.ips_to_decorations["10.0.0.1"].environment == "production"
