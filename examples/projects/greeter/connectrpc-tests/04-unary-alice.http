### 4. Unary: Alice
POST http://127.0.0.1:4769/helloworld.Greeter/SayHello
Content-Type: application/json

{"name":"Alice"}

> {%
client.test("returns Hello, Alice!", function() {
  client.assert(response.status === 200, "Expected 200, got " + response.status);
  const body = JSON.parse(response.body);
  client.assert(body.message === "Hello, Alice!", "Expected 'Hello, Alice!', got " + body.message);
});
%}
