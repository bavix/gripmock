### 3. Unary: Alex
POST http://127.0.0.1:4769/helloworld.Greeter/SayHello
Content-Type: application/json

{"name":"Alex"}

> {%
client.test("returns Hello, Alex!", function() {
  client.assert(response.status === 200, "Expected 200, got " + response.status);
  const body = JSON.parse(response.body);
  client.assert(body.message === "Hello, Alex!", "Expected 'Hello, Alex!', got " + body.message);
});
%}
